# =========================================================================
# Cartiae Rae Hair Studio - Production Environment Variables Template
# Copy this file to '.env' and fill in your live credentials before launching.
# =========================================================================

# 🌐 Application URL
VITE_APP_URL="https://cartiae-rae.com"

# 💳 Stripe Payment Gateway Keys
# Retrieve these from: Stripe Dashboard → Developers → API keys
# TEST MODE  (safe for development — no real money moves):
#   pk_test_...  /  sk_test_...
# LIVE MODE  (real payments — only when ready to go live):
#   pk_live_...  /  sk_live_...
#
# VITE_ prefix = exposed to the browser (publishable key only — safe)
# NO prefix    = server-only (secret key — never expose to browser)
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
# Webhook secret from: Stripe Dashboard → Developers → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_..."

# 🌐 Site URL — used by the Netlify function for success/cancel redirect URLs
# Must match your deployed domain exactly (no trailing slash)
SITE_URL="https://cartiaerae.netlify.app"

# 🗄️ Database Configurations (Supabase / Postgres / Firebase)
# Used by the backend to persist products, eBooks, orders, and contacts
DATABASE_URL="postgresql://postgres:password@db.supabase.co:5432/postgres"
# For client SDK integrations (like Supabase client-side JS)
# WARNING: Only expose VITE_ prefixed anon keys to the browser.
# NEVER expose the 'service_role' secret key (SUPABASE_SERVICE_ROLE_KEY) here!
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJhbGciOi..."

# 📦 File & Assets Storage (AWS S3 / Supabase Storage / Cloudinary)
# Used for storing product reference images, coily milestones, and digital eBooks
STORAGE_BUCKET_NAME="cartiae-rae-assets-prod"
STORAGE_BUCKET_REGION="us-east-1"
STORAGE_ACCESS_KEY_ID="AKIAIOSFODNN7EXAMPLE"
STORAGE_SECRET_ACCESS_KEY="wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"

# 🔐 Security, JWT & Administrative Session Keys
# Secret salt for signing secure expiring eBook download tokens
JWT_SECRET_KEY="super-secret-production-token-signing-key-change-me"
ADMIN_SESSION_SECRET="session-cookie-secret-key-change-me"

# ✉ SMTP Email Server Settings (AWS SES / SendGrid / Mailgun)
# Used to transmit eBook download links and order transaction details
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASSWORD="SG.example-apikey-here"
SMTP_FROM_EMAIL="orders@cartiae-rae.com"
