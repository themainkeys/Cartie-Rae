# =========================================================================
# Cartiae Rae Hair Studio — Environment Variables Template
# Copy this file to `.env` and fill in real values.
#
# SECURITY RULES:
#   • VITE_ prefix  = bundled into the browser. ONLY put public/publishable
#                     values here (publishable keys, anon keys, public URLs).
#   • NO prefix     = server-only. Read exclusively by Netlify functions /
#                     backend. NEVER prefix a secret with VITE_ — that ships it
#                     to every visitor.
#
# The app runs in a clearly-labeled DEMO mode when the frontend integrations
# below are absent, so nothing here is required just to boot the site locally.
# =========================================================================

# ─────────────────────────────────────────────────────────────────────────
# FRONTEND (safe to expose — compiled into the browser bundle)
# ─────────────────────────────────────────────────────────────────────────

# Supabase — URL + anon/publishable key.
# Setting these two ALONE enables media uploads to Supabase Storage, but the admin
# console stays in demo mode until you ALSO set VITE_SUPABASE_BACKEND below.
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="your-anon-key-here"

# Turn on REAL admin authentication (email+password via Supabase Auth) instead of
# the passwordless demo role-picker. Requires the `admin_users` / `contact_requests`
# tables + at least one staff row (see supabase/auth_full_setup.sql). Only set this
# to "true" AFTER those exist, or you'll lock yourself out (no demo fallback).
VITE_SUPABASE_BACKEND="true"

# Stripe — PUBLISHABLE key only (starts with pk_test_ or pk_live_).
# When set, the storefront enables live checkout; when missing, checkout stays
# in demo mode and never charges a card. The SECRET key is NOT set here.
VITE_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Public app URL (optional).
VITE_APP_URL="https://cartiae-rae.com"

# ─────────────────────────────────────────────────────────────────────────
# SERVER-ONLY (never exposed to the browser)
# Set these in the Netlify dashboard → Site settings → Environment variables.
# Used by netlify/functions/create-checkout-session.js and any future backend.
# ─────────────────────────────────────────────────────────────────────────

# Stripe SECRET key (starts with sk_test_ or sk_live_). SERVER ONLY.
STRIPE_SECRET_KEY="sk_test_..."

# Stripe webhook signing secret (for a future order/fulfillment webhook). SERVER ONLY.
STRIPE_WEBHOOK_SECRET="whsec_..."

# Site URL used by the checkout function to build success/cancel redirects
# (no trailing slash). SERVER ONLY.
SITE_URL="https://cartiaerae.netlify.app"

# ─────────────────────────────────────────────────────────────────────────
# SERVER-ONLY — for features that are NOT yet built (documented for later)
# These belong to a backend / serverless function, never the frontend bundle.
# ─────────────────────────────────────────────────────────────────────────

# Supabase service-role key — full DB access. SERVER ONLY. Needed to generate
# signed eBook download URLs and to run privileged writes. NEVER use VITE_ here.
# SUPABASE_SERVICE_ROLE_KEY="service-role-key-here"

# Private storage bucket for eBook files + product/media uploads (S3 / Supabase
# Storage / Cloudinary). Files must be PRIVATE; deliver via short-lived signed URLs.
# STORAGE_BUCKET_NAME="cartiae-rae-assets-prod"
# STORAGE_REGION="us-east-1"

# Transactional email (SendGrid / SES / Mailgun) for order + download emails.
# SMTP_HOST="smtp.sendgrid.net"
# SMTP_PORT=587
# SMTP_USER="apikey"
# SMTP_PASSWORD="your-smtp-api-key"
# SMTP_FROM_EMAIL="orders@cartiae-rae.com"
